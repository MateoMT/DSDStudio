<Window x:Class="IDE.Views.Select"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IDE.Views" xmlns:local1="clr-namespace:IDE.ViewModels" xmlns:local2="clr-namespace:IDE.Services" d:DataContext="{d:DesignInstance Type=local1:SelectViewModel}"
        mc:Ignorable="d"
        Background="#1E1F22"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Title="Welcome to Normal DSD" Height="350" Width="400">


    <StackPanel >
                <Border Background="#FF3B3B3B" Height="30" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="Welcome to DSDStudio" Foreground="White" VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0"/>
                </StackPanel>
                <Button Cursor="Hand"  Background="Transparent" BorderBrush="Transparent" HorizontalAlignment="Right" Command="{Binding CloseWindowCommand}">
                    <Image Source="/Resources/Icons/close.png"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </DockPanel>
        </Border>
        <Border Height="50" Background="Transparent"/>
        <TextBlock Text="Welcome to DSDStudio" Foreground="WhiteSmoke" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
        <Border Height="25" Background="Transparent"/>
        <TextBlock Text="Please select your operation" Foreground="WhiteSmoke" FontSize="16" FontWeight="Thin" VerticalAlignment="Center" HorizontalAlignment="Center" />
        <Border Height="40" Background="Transparent"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <StackPanel>
                <Button Width="60" Height="60" Background="#FF3B3B3B" Cursor="Hand" Command="{Binding CreateNewFileCommand}">
                    <Image Source="/Resources/Icons/new.png" Height="45" Width="45" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <TextBlock Text="New"  Foreground="White"  FontWeight="Thin" HorizontalAlignment="Center" Background="Transparent"></TextBlock>
            </StackPanel>
            <Border Width="100" Background="Transparent"/>
            <StackPanel>
                <Button Width="60" Height="60" Background="#FF3B3B3B" Cursor="Hand" Command="{Binding OpenFileCommand}">
                    <Image Source="/Resources/Icons/open.png" Height="45" Width="45" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <TextBlock Text="Open"  Foreground="White"  FontWeight="Thin" HorizontalAlignment="Center" Background="Transparent"></TextBlock>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
