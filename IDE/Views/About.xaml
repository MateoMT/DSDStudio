<Window x:Class="IDE.Views.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IDE.Views"
        xmlns:viewmodels="clr-namespace:IDE.ViewModels"
        mc:Ignorable="d"
        Background="#0f1E1F22"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Title="About" Height="360" Width="480"
        d:DataContext="{d:DesignInstance Type=viewmodels:AboutViewModel}"
        ShowInTaskbar="False">
    <Border BorderBrush="#FF3B3B3B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Background="#FF3B3B3B" Height="30" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="About" Foreground="White" VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0"/>
                    </StackPanel>
                    <Button Cursor="Hand"  Background="Transparent" BorderBrush="Transparent" HorizontalAlignment="Right" Command="{Binding CloseCommand}">
                        <Image Source="/Resources/Icons/close.png"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="20">
                <Image Source="/Resources/Icons/logo.png" Width="64" Height="64" Margin="0,10" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding AppTitle}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
                <TextBlock Text="{Binding AppVersion}" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,5"/>
                <TextBlock Text="{Binding Copyright}" Foreground="LightGray" FontSize="12" HorizontalAlignment="Center" Margin="0,5"/>
                <TextBlock Text="{Binding Description}" Foreground="White" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,15"/>
            </StackPanel>

            <Button Grid.Row="2" Content="OK" Width="80" Height="30" 
                    Command="{Binding CloseCommand}" 
                    Background="#FF3B3B3B" Foreground="White" BorderBrush="#FF8B8B8B"
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
