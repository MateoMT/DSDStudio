<Window x:Class="IDE.Init"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IDE"
        mc:Ignorable="d"
        Title="NormalDSD Starting..." Height="300" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="#B2FFFFFF" BorderThickness="1,1,1,1"  WindowStartupLocation="CenterScreen" Topmost="True" Cursor="Wait" ShowInTaskbar="False">
    <Window.BorderBrush>
        <LinearGradientBrush EndPoint="0,1" StartPoint="1,0">
            <GradientStop Color="Red" Offset="1"/>
            <GradientStop Color="Orange" Offset="0.83"/>
            <GradientStop Color="Yellow" Offset="0.67"/>
            <GradientStop Color="Green" Offset="0.5"/>
            <GradientStop Color="Blue" Offset="0.33"/>
            <GradientStop Color="Indigo" Offset="0.17"/>
            <GradientStop Color="Violet" Offset="0"/>
        </LinearGradientBrush>
    </Window.BorderBrush>
    <Grid>
        <Label x:Name="Title" Content="DSDStudio" HorizontalAlignment="Left" VerticalAlignment="Center" Width="400" Height="50" FontSize="48" FontWeight="Bold" Foreground="#FF000000" Background="#00FFFFFF" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0,0,0,0" Margin="0,0,0,0" BorderThickness="0,0,0,0" BorderBrush="#00FFFFFF" Cursor="Arrow" IsHitTestVisible="False" IsEnabled="True" IsTabStop="False" Focusable="False" AllowDrop="False" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderTransformOrigin="0.5,0.5">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0.496"/>
                    <RotateTransform/>
                    <TranslateTransform X="-0.108"/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label x:Name="Status" Content="Starting..." HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="142" HorizontalContentAlignment="Right" RenderTransformOrigin="0.5,0.5" Height="50" VerticalContentAlignment="Bottom" FontSize="24">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0.496"/>
                    <RotateTransform/>
                    <TranslateTransform X="-0.108"/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
    </Grid>
</Window>