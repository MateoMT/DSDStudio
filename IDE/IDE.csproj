<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>False</UseWindowsForms>
    <ApplicationIcon>favicon [256x256].ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Icons\close.png" />
    <None Remove="Resources\Icons\logo.png" />
    <None Remove="Resources\Icons\maxsize.png" />
    <None Remove="Resources\Icons\minsize.png" />
    <None Remove="Resources\Icons\new.png" />
    <None Remove="Resources\Icons\open.png" />
    <None Remove="Resources\Icons\restore.png" />
    <None Remove="Themes\dsd.xshd" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="Themes\DarkMenu.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="favicon [256x256].ico" />
    <EmbeddedResource Include="Themes\dsd.xshd">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Fonts\LXGW.ttf" />
    <Resource Include="Resources\Icons\close.png" />
    <Resource Include="Resources\Icons\logo.png" />
    <Resource Include="Resources\Icons\maxsize.png" />
    <Resource Include="Resources\Icons\minsize.png" />
    <Resource Include="Resources\Icons\new.png" />
    <Resource Include="Resources\Icons\open.png" />
    <Resource Include="Resources\Icons\restore.png" />
    <Resource Include="Themes\DarkMenu.xaml" />
  </ItemGroup>

  <ItemGroup>
