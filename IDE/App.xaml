<Application x:Class="IDE.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IDE" 
             xmlns:services="clr-namespace:IDE.Services" 
             xmlns:converters="clr-namespace:IDE.Converters">
    <Application.Resources>
        <services:NavigationService x:Key="NavigationService" />
        <services:FileService x:Key="FileService" />
        
        <FontFamily x:Key="GlobalFont">pack://application:,,,/IDE;component/Resources/Fonts/FiraCode.#Fira Code</FontFamily>
        

        <Style TargetType="Window">
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        

        <Style TargetType="TextElement">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
 
        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="Menu">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
        
        <Style TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{StaticResource GlobalFont}"/>
        </Style>
    </Application.Resources>
</Application>
